<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground"
    android:fitsSystemWindows="true">

    <!-- ==================== Header Section ==================== -->
    <RelativeLayout
        android:id="@+id/sprintsHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sprints"
            android:textColor="?attr/colorOnBackground"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/sprintsHeader"
            android:layout_marginTop="4dp"
            android:text="Track your collaboration sessions"
            android:textColor="@color/text_muted"
            android:textSize="12sp" />
    </RelativeLayout>

    <!-- ==================== Filter Section ==================== -->
    <HorizontalScrollView
        android:id="@+id/filterScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/sprintsHeader">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button
                android:id="@+id/btnAllSprints"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:backgroundTint="@color/brand_blue"
                android:text="All"
                android:textAllCaps="false"
                android:textColor="@color/text_white"
                app:cornerRadius="20dp" />
            <Button
                android:id="@+id/btnLiveSprints"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="@color/input_bg"
                android:text="Live"
                android:textAllCaps="false"
                android:textColor="@color/text_muted"
                app:cornerRadius="20dp" />
            <Button
                android:id="@+id/btnUpcomingSprints"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="@color/input_bg"
                android:text="Upcoming"
                android:textAllCaps="false"
                android:textColor="@color/text_muted"
                app:cornerRadius="20dp" />
            <Button
                android:id="@+id/btnAttendedSprints"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="@color/input_bg"
                android:text="Attended"
                android:textAllCaps="false"
                android:textColor="@color/text_muted"
                app:cornerRadius="20dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- ==================== Content Section ==================== -->
    <ProgressBar
        android:id="@+id/loadingProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:indeterminateTint="@color/brand_blue"
        app:layout_constraintTop_toBottomOf="@id/filterScroll"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:id="@+id/sprintsScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:fillViewport="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/filterScroll">

        <LinearLayout
            android:id="@+id/sprintsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="20dp" />
    </ScrollView>

    <!-- ==================== Empty State ==================== -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/filterScroll">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No sprints yet"
            android:textColor="@color/text_muted"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Start a collaboration session"
            android:textColor="@color/text_muted"
            android:textSize="13sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
