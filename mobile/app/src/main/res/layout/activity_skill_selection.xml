<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnContinue">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_menu_revert"
                    app:tint="@color/text_white" />
                <TextView
                    android:id="@+id/tvSkip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:text="Skip"
                    android:textColor="@color/text_muted" />
            </RelativeLayout>

            <!-- Profile Section - Step 1 -->
            <LinearLayout
                android:id="@+id/profileSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="Build your Tech Profile"
                    android:textColor="@color/text_white"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Step 1: Tell us about yourself"
                    android:textColor="@color/text_muted"
                    android:textSize="14sp" />

                <!-- Full Name Input -->
                <EditText
                    android:id="@+id/etFullName"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/input_background"
                    android:hint="Full Name"
                    android:inputType="text"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_muted"
                    android:textSize="14sp" />

                <!-- Bio Input -->
                <EditText
                    android:id="@+id/etBio"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/input_background"
                    android:hint="Bio (Optional)"
                    android:inputType="text"
                    android:paddingHorizontal="16dp"
                    android:gravity="top"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_muted"
                    android:textSize="14sp" />

                <!-- City Input -->
                <EditText
                    android:id="@+id/etCity"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/input_background"
                    android:hint="City"
                    android:inputType="text"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_muted"
                    android:textSize="14sp" />

                <!-- College Input -->
                <EditText
                    android:id="@+id/etCollege"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/input_background"
                    android:hint="College/University"
                    android:inputType="text"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_muted"
                    android:textSize="14sp" />

                <!-- GitHub Username Input -->
                <EditText
                    android:id="@+id/etGithubUsername"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/input_background"
                    android:hint="GitHub Username (Optional)"
                    android:inputType="text"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_muted"
                    android:textSize="14sp" />

                <!-- LinkedIn URL Input -->
                <EditText
                    android:id="@+id/etLinkedinUrl"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/input_background"
                    android:hint="LinkedIn URL (Optional)"
                    android:inputType="textUri"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_muted"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- Skills Section - Step 2 -->
            <LinearLayout
                android:id="@+id/skillsSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:text="Build your Tech Profile"
                    android:textColor="@color/text_white"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Step 2: Select at least 3 technologies"
                    android:textColor="@color/text_muted"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/etSearchSkills"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/input_background"
                    android:drawableStart="@drawable/ic_search"
                    android:drawablePadding="12dp"
                    android:drawableTint="@color/text_muted"
                    android:hint="Search skills (e.g. Rust, Docker)..."
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_muted"
                    android:textSize="14sp" />

                <!-- Dynamic skills container populated by Activity -->
                <LinearLayout
                    android:id="@+id/skillsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="24dp" />

                <!-- Selected Skills by Proficiency Level Section -->
                <LinearLayout
                    android:id="@+id/selectedSkillsSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="32dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your Selected Skills"
                        android:textColor="@color/text_white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <!-- Beginner Section -->
                    <LinearLayout
                        android:id="@+id/beginnerSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="16dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🟢 Beginner"
                            android:textColor="@color/text_muted"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/beginnerSkillsGroup"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>

                    <!-- Intermediate Section -->
                    <LinearLayout
                        android:id="@+id/intermediateSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="16dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🟡 Intermediate"
                            android:textColor="@color/text_muted"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/intermediateSkillsGroup"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>

                    <!-- Advanced/Expert Section -->
                    <LinearLayout
                        android:id="@+id/advancedSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="16dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔴 Expert"
                            android:textColor="@color/text_muted"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/advancedSkillsGroup"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnContinue"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_margin="24dp"
        android:text="Continue"
        android:textAllCaps="false"
        android:backgroundTint="@color/brand_blue"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>