<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/input_bg"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ==================== Header: Session Type + Status ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/sessionTypeText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Debug"
                android:textColor="@color/text_white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/statusBadge"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="Pending"
                android:textColor="@color/text_white"
                android:paddingHorizontal="12dp"
                android:gravity="center"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_status_pending"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- ==================== Message ==================== -->
        <TextView
            android:id="@+id/messageText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Looking for someone to help debug my app"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:layout_marginBottom="12dp"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- ==================== Created At ==================== -->
        <TextView
            android:id="@+id/createdAtText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Created: 2 hours ago"
            android:textColor="@color/text_muted"
            android:textSize="11sp"
            android:layout_marginBottom="12dp" />

        <!-- ==================== Cancel Button ==================== -->
        <Button
            android:id="@+id/btnCancel"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Cancel Request"
            android:textColor="@color/text_white"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_outline"
            android:visibility="gone" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
