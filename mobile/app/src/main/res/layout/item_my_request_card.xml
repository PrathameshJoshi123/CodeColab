<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/md_theme_light_surface_variant"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- ==================== Header: My Request Badge + Status ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📌 My Request"
                android:textColor="@color/md_theme_light_on_surface_variant"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/statusBadge"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:text="Pending"
                android:textColor="@color/text_white"
                android:paddingHorizontal="10dp"
                android:gravity="center"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/bg_status_pending" />

        </LinearLayout>

        <!-- ==================== Session Type + Message ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/sessionTypeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Debug"
                android:textColor="@color/md_theme_light_on_surface"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/messageText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Looking for someone to help debug my app"
                android:textColor="@color/md_theme_light_on_surface_variant"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- ==================== Metadata Row ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/createdAtText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Created: 2 hours ago"
                android:textColor="@color/md_theme_light_outline_variant"
                android:textSize="10sp" />

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="Cancel"
                android:textColor="@color/md_theme_light_error"
                android:textSize="10sp"
                android:paddingHorizontal="8dp"
                android:background="@android:color/transparent"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
