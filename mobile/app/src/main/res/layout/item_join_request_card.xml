<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/input_bg"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/textSessionType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Debug"
            android:textColor="@color/brand_blue"
            android:textStyle="bold"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/textMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Need help with API integration"
            android:textColor="@color/text_white"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/textRequiredSkills"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Required Skills: Java, Firebase"
            android:textColor="@color/text_muted"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/textInterestedCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Interested Users: 0"
            android:textColor="@color/text_white"
            android:textStyle="bold"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/textInterestedPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="No interested users yet"
            android:textColor="@color/text_muted"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/textCreatedAt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Posted recently"
            android:textColor="@color/text_muted"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btnViewInterested"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="12dp"
            android:text="View Interested Users"
            android:textColor="@color/text_white"
            android:textStyle="bold"
            android:textSize="12sp"
            android:background="@drawable/bg_button_solid_blue" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
