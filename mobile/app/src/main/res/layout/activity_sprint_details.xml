<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/btnCancelDetails"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Back"
                    android:textColor="@color/brand_blue"
                    android:textSize="16sp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Sprint Details"
                    android:textColor="@color/text_white"
                    android:textStyle="bold"
                    android:textSize="18sp" />
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SPRINT GOAL"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginTop="32dp"
                android:letterSpacing="0.1"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvGoalTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DESCRIPTION"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginTop="20dp"
                android:letterSpacing="0.1"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textColor="@color/text_white"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MEETING LINK"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginTop="20dp"
                android:letterSpacing="0.1"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMeetingLink"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textColor="@color/brand_blue"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REPOSITORY"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginTop="20dp"
                android:letterSpacing="0.1"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRepoLink"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No repository"
                android:textColor="@color/brand_blue"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DURATION"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginTop="20dp"
                android:letterSpacing="0.1"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="60 minutes"
                android:textColor="@color/text_white"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PARTICIPANTS"
                android:textColor="@color/text_muted"
                android:textSize="12sp"
                android:layout_marginTop="20dp"
                android:letterSpacing="0.1"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/participantsLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TO-DO CHECKLIST"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textSize="12sp"
                android:layout_marginTop="32dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <EditText
                    android:id="@+id/etNewTodo"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:background="@drawable/input_background"
                    android:hint="Add a new todo..."
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/text_white"
                    android:textColorHint="@color/text_muted" />

                <Button
                    android:id="@+id/btnAddTodo"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginStart="8dp"
                    android:text="+"
                    android:textColor="@color/text_white"
                    android:textSize="24sp"
                    android:backgroundTint="@color/brand_blue"
                    app:cornerRadius="12dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/todosLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp" />

            <!-- Action Buttons Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="24dp">

                <Button
                    android:id="@+id/btnJoinSprint"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Join Sprint"
                    android:textColor="@color/text_white"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:backgroundTint="@color/brand_blue"
                    android:visibility="gone"
                    app:cornerRadius="12dp" />

                <Button
                    android:id="@+id/btnStartSprint"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Start Sprint"
                    android:textColor="@color/text_white"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:backgroundTint="@color/brand_blue"
                    android:visibility="gone"
                    android:layout_marginTop="12dp"
                    app:cornerRadius="12dp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/loadingProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
