<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext traffic to local development addresses -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Emulator special IP -->
        <domain includeSubdomains="true">10.0.2.2</domain>
        <!-- Localhost -->
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <!-- Local backend server -->
        <domain includeSubdomains="true">192.168.171.23</domain>
        <!-- Local network IPs (192.168.x.x and 172.x.x.x ranges) -->
        <domain includeSubdomains="true">192.168.0.0</domain>
        <domain includeSubdomains="true">172.16.0.0</domain>
    </domain-config>
    
    <!-- For production, enforce HTTPS for all other domains -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">*.example.com</domain>
    </domain-config>
</network-security-config>
